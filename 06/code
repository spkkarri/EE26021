import numpy as np 
import pandas as pd 
import matplotlib.pyplot as plt 
from sklearn.preprocessing import MinMaxScaler 
import gym 
from gym import spaces 
from stable_baselines3 import PPO 
from stable_baselines3.common.vec_env import DummyVecEnv 
# ========================================= 
# LOAD DATA (Database.csv) 
# ========================================= 
df = pd.read_csv("Database.csv", on_bad_lines='skip', engine='python') 
df.columns = df.columns.str.strip() 
df = df[['PV_production','Wind_production','Electric_demand']].dropna() 
data = df.values 
# Normalize for RL stability 
scaler = MinMaxScaler() 
data_norm = scaler.fit_transform(data) 
# ========================================= 
# MICROGRID ENVIRONMENT (NO BATTERY) 
# ========================================= 
class MicrogridEnv(gym.Env): 
def __init__(self, data): 
super().__init__() 
self.data = data 
        self.max_steps = len(data) 
        self.step_id = 0 
 
        # state: solar, wind, load 
        self.observation_space = spaces.Box(0,1,(3,),dtype=np.float32) 
 
        # action: weights for solar, wind, grid 
        self.action_space = spaces.Box(0,1,(3,),dtype=np.float32) 
 
    def reset(self): 
        self.step_id = 0 
        return self.data[self.step_id] 
 
    def step(self, action): 
 
        solar_avail, wind_avail, load = self.data[self.step_id] 
 
        # ---------------------------- 
        # ACTION → NORMALIZED WEIGHTS 
        # ---------------------------- 
        action = np.clip(action, 0, 1) 
        weights = action / (np.sum(action) + 1e-8) 
 
        w_solar, w_wind, w_grid = weights 
 
        demand = load 
 
        # ---------------------------- 
        # ENERGY DISTRIBUTION (REALISTIC) 
        # ---------------------------- 
        # Solar first 
        solar_used = min(solar_avail, w_solar * demand) 
 
        # Wind next 
        remaining_after_solar = demand - solar_used 
        wind_used = min(wind_avail, w_wind * remaining_after_solar) 
 
        # Grid fills remaining demand 
        remaining = demand - (solar_used + wind_used) 
        grid_used = max(0, remaining) 
 
        total_supply = solar_used + wind_used + grid_used 
 
        # ---------------------------- 
        # REWARD FUNCTION (BALANCED) 
        # ---------------------------- 
        scale = demand + 1e-6 
 
        mismatch = abs(total_supply - demand) / scale 
        renewable = solar_used + wind_used 
 
        renewable_ratio = renewable / scale 
        grid_ratio = grid_used / scale 
 
        reward = 0 
 
        # 1. Strong balance 
        reward += 12 * (1 - mismatch) 
 
        # 2. Renewable usage 
        reward += 6 * renewable_ratio 
 
        # 3. Grid penalty (moderate) 
        reward -= 2.0 * grid_ratio 
 
        # 4. Use available solar/wind 
        if solar_avail > 0.2: 
            reward += 2 * (solar_used / (solar_avail + 1e-6)) 
 
        if wind_avail > 0.2: 
            reward += 2 * (wind_used / (wind_avail + 1e-6)) 
 
        # 5. Penalize ignoring renewables 
        if solar_avail > 0.2 and solar_used < 0.05: 
            reward -= 3 
 
        if wind_avail > 0.2 and wind_used < 0.05: 
            reward -= 3 
 
        # 6. Penalize not using grid when needed 
        if remaining > 0.05 and grid_used < 0.05: 
            reward -= 3 
 
        # 7. Bonus for perfect match 
        if mismatch < 0.01: 
            reward += 6 
 
        # ---------------------------- 
        self.step_id += 1 
        done = self.step_id >= self.max_steps - 1 
 
        return self.data[self.step_id], reward, done, {} 
 
# ========================================= 
# CREATE ENV 
# ========================================= 
env = DummyVecEnv([lambda: MicrogridEnv(data_norm)]) 
 
# ========================================= 
# TRAIN PPO 
# ========================================= 
model = PPO( 
    "MlpPolicy", 
    env, 
    learning_rate=2e-4, 
    n_steps=4096, 
    batch_size=128, 
    gamma=0.99, 
    ent_coef=0.03, 
    verbose=1 
) 
 
model.learn(total_timesteps=80000) 
 
# ========================================= 
# TEST MODEL 
# ========================================= 
test_env = MicrogridEnv(data_norm) 
obs = test_env.reset() 
 
print("\n  OPTIMIZED ENERGY DISTRIBUTION\n") 
 
solar_log, wind_log, grid_log, reward_log = [], [], [], [] 
 
for i in range(20): 
    action, _ = model.predict(obs) 
 
    obs, reward, done, _ = test_env.step(action) 
 
    solar_avail, wind_avail, load = data_norm[i] 
 
    weights = action / (np.sum(action) + 1e-8) 
    w_s, w_w, w_g = weights 
 
    solar_used = min(solar_avail, w_s * load) 
    wind_used = min(wind_avail, w_w * (load - solar_used)) 
    grid_used = max(0, load - (solar_used + wind_used)) 
 
    solar_log.append(solar_used) 
    wind_log.append(wind_used) 
    grid_log.append(grid_used) 
    reward_log.append(reward) 
 
    print(f"Step {i+1}") 
    print(f"Demand: {load:.3f}") 
    print(f"Solar Used: {solar_used:.3f}") 
    print(f"Wind Used : {wind_used:.3f}") 
    print(f"Grid Used : {grid_used:.3f}") 
    print(f"Renewable %: {(solar_used+wind_used)/load*100:.2f}%") 
    print(f"Reward: {reward:.3f}") 
    print("-"*40) 
 
    if done: 
        break 
 
