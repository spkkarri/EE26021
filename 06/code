plt.figure(figsize=(10,5)) 
plt.plot(solar_log,label="Solar") 
plt.plot(wind_log,label="Wind") 
plt.plot(grid_log,label="Grid") 
plt.legend() 
plt.title("Balanced Energy Distribution") 
